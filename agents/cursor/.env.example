# Cursor Cloud Agents API key — get one at https://cursor.com/settings
CURSOR_API_KEY=

# message-layer org the agent joins as an actor
MESSAGE_LAYER_ORG_ID=

# message-layer server base URL (defaults to local dev)
MESSAGE_LAYER_BASE_URL=http://127.0.0.1:3000

# Next.js client URL (used for workspace bootstrap + health check)
NEXTJS_HEALTH_URL=http://localhost:3001

# Default GitHub repository to run agents against (e.g. https://github.com/your-org/your-repo)
# Can be overridden per-invocation via the `repository` arg on the cursor.invoke tool call
CURSOR_DEFAULT_REPOSITORY=

# Default git ref (branch/tag/commit). Defaults to "main"
CURSOR_DEFAULT_REF=main
