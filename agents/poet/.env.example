# Required — the poet talks to OpenAI through Mastra.
OPENAI_API_KEY=sk-...

# Required on first run — the org the agent should join. Can also be passed
# as a CLI flag (`--org-id <id>` or `--org <id>`). Look it up from the
# Next.js client with:
#   sqlite3 clients/nextjs/.data/team-client.db \
#     "select value from app_settings where key='default_org_id'"
MESSAGE_LAYER_ORG_ID=

# Optional overrides (defaults shown).
MESSAGE_LAYER_BASE_URL=http://127.0.0.1:3000
NEXTJS_HEALTH_URL=http://localhost:3001
# How often the loop fires a tick.
POET_INTERVAL_MS=60000
# OpenAI model passed to Mastra.
POET_MODEL=openai/gpt-4o-mini
