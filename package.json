{
  "name": "message-layer",
  "version": "0.1.0",
  "type": "module",
  "description": "Headless messaging and coordination layer for humans, agents, and apps",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agent-kernel": {
      "import": "./dist/agent-kernel/index.js",
      "types": "./dist/agent-kernel/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./plugins/api-key-auth": {
      "import": "./dist/plugins/api-key-auth.js",
      "types": "./dist/plugins/api-key-auth.d.ts"
    },
    "./plugins/durable-streams": {
      "import": "./dist/plugins/durable-streams.js",
      "types": "./dist/plugins/durable-streams.d.ts"
    },
    "./plugins/durable-streams-storage": {
      "import": "./dist/plugins/durable-streams-storage.js",
      "types": "./dist/plugins/durable-streams-storage.d.ts"
    },
    "./plugins/event-logger": {
      "import": "./dist/plugins/event-logger.js",
      "types": "./dist/plugins/event-logger.d.ts"
    },
    "./plugins/health-meta": {
      "import": "./dist/plugins/health-meta.js",
      "types": "./dist/plugins/health-meta.d.ts"
    },
    "./plugins/request-logging": {
      "import": "./dist/plugins/request-logging.js",
      "types": "./dist/plugins/request-logging.d.ts"
    },
    "./plugins/memory": {
      "import": "./dist/plugins/memory.js",
      "types": "./dist/plugins/memory.d.ts"
    },
    "./plugins/search": {
      "import": "./dist/plugins/search.js",
      "types": "./dist/plugins/search.d.ts"
    },
    "./plugins/webhooks": {
      "import": "./dist/plugins/webhooks.js",
      "types": "./dist/plugins/webhooks.d.ts"
    },
    "./plugins/websocket": {
      "import": "./dist/plugins/websocket.js",
      "types": "./dist/plugins/websocket.d.ts"
    },
    "./storage/pglite": {
      "import": "./dist/storage/pglite.js",
      "types": "./dist/storage/pglite.d.ts"
    },
    "./storage/postgres": {
      "import": "./dist/storage/postgres.js",
      "types": "./dist/storage/postgres.d.ts"
    },
    "./storage/s3": {
      "import": "./dist/storage/s3.js",
      "types": "./dist/storage/s3.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "client:terminal": "tsx clients/terminal/client.ts",
    "client:terminal:demo": "tsx clients/terminal/client.ts --smoke",
    "demo:hero": "tsx scripts/hero-flow.ts",
    "client:nextjs": "pnpm --dir clients/nextjs run dev",
    "client:nextjs:build": "pnpm --dir clients/nextjs run build",
    "agent:poet": "pnpm --dir agents/poet run start",
    "agent:poet:once": "pnpm --dir agents/poet run once",
    "agent:assistant": "pnpm --dir agents/assistant run start",
    "agent:assistant:once": "pnpm --dir agents/assistant run once",
    "agent:cursor": "pnpm --dir agents/cursor run start",
    "agent:cursor:once": "pnpm --dir agents/cursor run once"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@electric-sql/pglite": "0.3.11",
    "@hono/node-server": "1.14.4",
    "@mariozechner/pi-ai": "0.66.1",
    "@mariozechner/pi-coding-agent": "0.66.1",
    "hono": "4.9.7",
    "pg": "^8.20.0",
    "ws": "8.18.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.16.5",
    "@types/pg": "^8.20.0",
    "@types/ws": "8.18.1",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  }
}
